# Application
APP_NAME=learning-system
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Ports
FRONTEND_PORT=8080
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Frontend build/runtime
VITE_API_BASE_URL=/api/v1

# Database / cache
POSTGRES_DB=learning_system
POSTGRES_USER=learning_system
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+asyncpg://learning_system:change-this-db-password@postgres:5432/learning_system
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_STORE_EAGER_RESULT=true

# Auth
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_EMAIL=admin@example.com

# Workspace / Obsidian
WORKSPACE_HOST_PATH=./workspace
WORKSPACE_ROOT=/data/workspace
OBSIDIAN_HEADLESS_PATH=obsidian-headless
OBSIDIAN_VAULT=
OBSIDIAN_CONFIG_DIR=
OBSIDIAN_DEVICE_NAME=
